# =============================================================================
# Конфигурация Competency Analyzer
# Скопируйте этот файл в .env и заполните своими значениями
# =============================================================================

# ---------- hh.ru API ----------
# ID приложения hh.ru (можно получить на https://dev.hh.ru/)
HH_CLIENT_ID=
# Секрет приложения hh.ru
HH_CLIENT_SECRET=
# User-Agent для запросов (по умолчанию задан в коде)
# HH_USER_AGENT=CompetencyAnalyzer (не изменять, так как авторизация по почте для секретных данных для апи)

# ---------- YandexGPT ----------
# API-ключ Яндекс.Облака (для LLM-объяснений)
YC_API_KEY=
# ID каталога Яндекс.Облака
YC_FOLDER_ID=
# Модель YandexGPT (по умолчанию yandexgpt-lite)
# YANDEXGPT_MODEL=yandexgpt-lite

# ---------- HuggingFace ----------
# Токен Hugging Face для загрузки models (опционально, если модель требует авторизации)
HF_TOKEN=

# ---------- Логирование ----------
# Уровень логирования (DEBUG, INFO, WARNING, ERROR). По умолчанию INFO
# LOG_LEVEL=INFO

# ---------- Прочие параметры ----------
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
# GLOBAL_RANDOM_SEED=42
