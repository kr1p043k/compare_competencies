# === База данных ===
# Формат: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/compare_competencies
SECRET_KEY=change-me-to-random-string

# === hh.ru API ===
# Создать: https://dev.hh.ru/admin
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_USER_AGENT=CompetencyAnalyzer (your-email@example.com)

# === YandexGPT (опционально) ===
YC_API_KEY=
YC_FOLDER_ID=
# YANDEXGPT_MODEL=yandexgpt-lite

# === HuggingFace (опционально) ===
# Нужен для gated моделей (например, Llama)
HF_TOKEN=

# === CORS ===
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000
# LOG_LEVEL=DEBUG

# === Пайплайн ===
DEFAULT_AREA=1
DEFAULT_PERIOD_DAYS=30
DEFAULT_MAX_PAGES=20

# === n8n ===
N8N_API_KEY=
N8N_WEBHOOK_SECRET=
