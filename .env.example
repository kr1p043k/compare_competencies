# === База данных ===
# Формат: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/compare_competencies
DATABASE_ECHO=false

# === Безопасность (обязательно сменить!) ===
SECRET_KEY=change-me-to-random-string
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000
TOKEN_TTL_DAYS=7

# === hh.ru API ===
# Создать: https://dev.hh.ru/admin
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_USER_AGENT=CompetencyAnalyzer (your-email@example.com)
REQUEST_DELAY=0.1
MAX_RETRIES=3

# === Пайплайн ===
DEFAULT_AREA=1
DEFAULT_PERIOD_DAYS=30
DEFAULT_MAX_PAGES=20
DEFAULT_PER_PAGE=100

# === LLM (OpenAI-compatible, e.g. vLLM) ===
LLM_BASE_URL=http://localhost:8001/v1
LLM_API_KEY=
LLM_MODEL=qwen/Qwen3-Coder-480B-A35B-Instruct

# === YandexGPT (опционально) ===
YC_API_KEY=
YC_FOLDER_ID=
YANDEXGPT_MODEL=yandexgpt-lite

# === HuggingFace (опционально, для gated моделей) ===
HF_TOKEN=

# === n8n ===
N8N_API_KEY=
N8N_WEBHOOK_SECRET=

# === Эмбеддинги ===
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
SIMILARITY_THRESHOLD=0.80

# === Логирование ===
LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG
