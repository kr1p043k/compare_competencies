{
  "title": "Backend Metrics",
  "uid": "cc-backend",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": false,
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"backend\"}[5m]))",
          "legendFormat": "RPS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 50 }] }
        }
      }
    },
    {
      "title": "Request Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Active Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        { "expr": "sum(http_requests_in_progress{job=\"backend\"})", "legendFormat": "in-flight" }
      ]
    },
    {
      "title": "HTTP Status Codes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(http_requests_total{job=\"backend\",status=~\"2..\"}[5m]))", "legendFormat": "2xx" },
        { "expr": "sum(rate(http_requests_total{job=\"backend\",status=~\"4..\"}[5m]))", "legendFormat": "4xx" },
        { "expr": "sum(rate(http_requests_total{job=\"backend\",status=~\"5..\"}[5m]))", "legendFormat": "5xx" }
      ]
    },
    {
      "title": "Request Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(rate(http_request_size_bytes_sum{job=\"backend\"}[5m])) / sum(rate(http_request_size_bytes_count{job=\"backend\"}[5m]))", "legendFormat": "avg request" },
        { "expr": "sum(rate(http_response_size_bytes_sum{job=\"backend\"}[5m])) / sum(rate(http_response_size_bytes_count{job=\"backend\"}[5m]))", "legendFormat": "avg response" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Pipeline Duration",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 16 },
      "targets": [
        { "expr": "cc_pipeline_duration_seconds_max", "legendFormat": "last" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Active Pipelines",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 16 },
      "targets": [
        { "expr": "cc_active_pipelines", "legendFormat": "running" }
      ]
    },
    {
      "title": "Pipeline Runs (success / failure)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 16 },
      "targets": [
        { "expr": "sum(rate(cc_pipeline_runs_total{job=\"backend\",status=\"success\"}[5m]))", "legendFormat": "success" },
        { "expr": "sum(rate(cc_pipeline_runs_total{job=\"backend\",status=\"failure\"}[5m]))", "legendFormat": "failure" }
      ]
    },
    {
      "title": "Pipeline Stage Duration",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 16, "y": 16 },
      "targets": [
        { "expr": "cc_pipeline_stage_duration_seconds_max{job=\"backend\"}", "legendFormat": "{{stage}}" }
      ]
    },
    {
      "title": "Cache Operations",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 22 },
      "targets": [
        { "expr": "sum(rate(cc_skills_cache_operations_total{job=\"backend\",result=\"hit\"}[5m]))", "legendFormat": "hit" },
        { "expr": "sum(rate(cc_skills_cache_operations_total{job=\"backend\",result=\"miss\"}[5m]))", "legendFormat": "miss" }
      ]
    },
    {
      "title": "N8N Webhook Calls",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 22 },
      "targets": [
        { "expr": "sum(rate(cc_n8n_webhook_calls_total{job=\"backend\"}[5m])) by (event)", "legendFormat": "{{event}}" }
      ]
    },
    {
      "title": "Python GC & Memory",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 22 },
      "targets": [
        { "expr": "python_gc_objects_collected_total{job=\"backend\"}", "legendFormat": "gc collected" },
        { "expr": "process_resident_memory_bytes{job=\"backend\"}", "legendFormat": "RSS" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    }
  ]
}
