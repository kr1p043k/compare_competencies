> @limiter.limit("60/minute")
> async def get_market_competencies(
>     request: Request,
>     weights: dict[str, float] = Depends(deps.get_skill_weights),
> ):
!     top_skills = sorted(weights.items(), key=lambda x: x[1], reverse=True)[:100]
