    {
      "parameters": {
        "jsCode": "const r = $json.report;\nconst lang = $json.user_lang;\nconst d = new Date($json.generated_at).toLocaleDateString(lang === 'ru' ? 'ru-RU' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' });\n\nconst title = lang === 'ru' ? 'Еженедельный отчёт по рынку' : 'Weekly Market Report';\nconst tSummary = lang === 'ru' ? 'Резюме' : 'Executive Summary';\nconst tRising = lang === 'ru' ? 'Растущие тренды' : 'Rising Trends';\nconst tFalling = lang === 'ru' ? 'Падающие тренды' : 'Falling Trends';\nconst tTop = lang === 'ru' ? 'Топ навыков' : 'Top Skills';\nconst tRec = lang === 'ru' ? 'Рекомендации' : 'Recommendations';\nconst tInsights = lang === 'ru' ? 'Аналитика рынка' : 'Market Insights';\n\nlet html = '<!DOCTYPE html><html><head><meta charset=\"utf-8\"><style>';\nhtml += 'body{font-family:Arial,sans-serif;color:#333;max-width:800px;margin:0 auto;padding:20px}';\nhtml += 'h1{color:#1a73e8;border-bottom:2px solid #1a73e8;padding-bottom:10px}';\nhtml += 'h2{color:#333;margin-top:30px}';\nhtml += 'table{border-collapse:collapse;width:100%;margin:10px 0}';\nhtml += 'th,td{border:1px solid #ddd;padding:8px;text-align:left}';\nhtml += 'th{background:#1a73e8;color:#fff}';\nhtml += 'tr:nth-child(even){background:#f5f5f5}';\nhtml += '.rising{color:#0a0}';\nhtml += '.falling{color:#c00}';\nhtml += '.rec{background:#e8f5e9;border-left:4px solid #4caf50;padding:10px;margin:5px 0}';\nhtml += '.insights{background:#f0f8ff;padding:15px;border-radius:5px}';\nhtml += '</style></head><body>';\nhtml += '<h1>' + title + '</h1>';\nhtml += '<p><em>' + d + '</em></p>';\n\nhtml += '<h2>' + tSummary + '</h2>';\nhtml += '<p>' + (r.executive_summary || '') + '</p>';\n\nif (r.key_trends?.rising?.length) {\n  html += '<h2>' + tRising + '</h2><table><tr><th>Skill</th><th>Change</th><th>Interpretation</th></tr>';\n  r.key_trends.rising.forEach(t => {\n    html += '<tr><td><b>' + (t.skill || '') + '</b></td><td class=\"rising\">+' + (t.change_pct || '') + '%</td><td>' + (t.interpretation || '') + '</td></tr>';\n  });\n  html += '</table>';\n}\n\nif (r.key_trends?.falling?.length) {\n  html += '<h2>' + tFalling + '</h2><table><tr><th>Skill</th><th>Change</th><th>Interpretation</th></tr>';\n  r.key_trends.falling.forEach(t => {\n    html += '<tr><td><b>' + (t.skill || '') + '</b></td><td class=\"falling\">' + (t.change_pct || '') + '%</td><td>' + (t.interpretation || '') + '</td></tr>';\n  });\n  html += '</table>';\n}\n\nhtml += '<h2>' + tTop + '</h2><table><tr><th>#</th><th>Skill</th><th>Importance</th><th>Why Relevant</th></tr>';\n(r.top_skills_analysis || []).slice(0, 10).forEach((s, i) => {\n  html += '<tr><td>' + (i+1) + '</td><td><b>' + (s.skill || '') + '</b></td><td>' + (s.importance_rating || '') + '/10</td><td>' + (s.why_relevant || '') + '</td></tr>';\n});\nhtml += '</table>';\n\nhtml += '<h2>' + tRec + '</h2>';\n(r.recommendations || []).forEach(rec => {\n  html += '<div class=\"rec\">' + rec + '</div>';\n});\n\nif (r.market_insights) {\n  html += '<h2>' + tInsights + '</h2>';\n  html += '<div class=\"insights\">' + r.market_insights + '</div>';\n}\n\nhtml += '<hr><p style=\"color:#999;font-size:12px\">Generated by SFEDU AI Assistant | ' + new Date().toISOString() + '</p>';\nhtml += '</body></html>';\n\nreturn [{ json: { email_html: html, email_subject: title + ' — ' + d, generated_at: $json.generated_at } }];"
      },
