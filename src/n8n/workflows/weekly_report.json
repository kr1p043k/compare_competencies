      "id": "54a2ae77-2180-4421-a840-ce5539006783",
      "name": "OpenAI Report",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        5696,
        4160
      ]
    },
    {
      "parameters": {
        "jsCode": "const provider = $('Build Report Prompt').first().json.llm_provider;\nconst item = items[0].json;\nlet raw = provider === 'openai'\n  ? (item?.choices?.[0]?.message?.content ?? '')\n  : (item?.candidates?.[0]?.content?.parts?.[0]?.text ?? '');\nraw = String(raw).replace(/```json|```/g, '').trim();\n\nlet report;\ntry {\n  report = JSON.parse(raw);\n} catch (e) {\n  report = {\n    executive_summary: 'Report generation failed — raw LLM output saved.',\n    top_skills_analysis: [],\n    key_trends: { rising: [], falling: [] },\n    profile_highlights: [],\n    recommendations: ['Retry report generation'],\n    market_insights: ''\n  };\n}\n\nconst baseData = $('Aggregate Report Data').first().json;\nreturn [{\n  json: {\n    report: report,\n    raw_data_summary: {\n      skill_count: (baseData.top_skills || []).length,\n      profile_count: Object.keys(baseData.profiles || {}).length,\n      vacancy_stats: baseData.vacancy_stats\n    },\n    generated_at: baseData.generated_at,\n    user_lang: baseData.user_lang\n  }\n}];"
      },
      "id": "a75c1759-2a5a-4c0f-9d11-636354f0445b",
      "name": "Parse Report",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        5968,
        3984
      ]
    },
    {
      "parameters": {
        "jsCode": "const r = $json.report;\nconst lang = $json.user_lang;\nconst d = new Date($json.generated_at).toLocaleDateString(lang === 'ru' ? 'ru-RU' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' });\n\nlet msg = lang === 'ru'\n  ? '<b>📊 Еженедельный отчёт по рынку</b>\\n<i>' + d + '</i>\\n\\n'\n  : '<b>📊 Weekly Market Report</b>\\n<i>' + d + '</i>\\n\\n';\n\nmsg += '<b>' + (lang === 'ru' ? '📋 Резюме:' : '📋 Executive Summary:') + '</b>\\n';\nmsg += (r.executive_summary || '') + '\\n\\n';\n\nif (r.key_trends?.rising?.length) {\n  msg += '<b>📈 ' + (lang === 'ru' ? 'Растущие навыки:' : 'Rising Skills:') + '</b>\\n';\n  r.key_trends.rising.slice(0, 5).forEach(t => {\n    msg += '  \\u2022 <b>' + (t.skill || '') + '</b> ' + (t.change_pct || '') + '% — ' + (t.interpretation || '') + '\\n';\n  });\n  msg += '\\n';\n}\n\nif (r.key_trends?.falling?.length) {\n  msg += '<b>📉 ' + (lang === 'ru' ? 'Падающие навыки:' : 'Falling Skills:') + '</b>\\n';\n  r.key_trends.falling.slice(0, 5).forEach(t => {\n    msg += '  \\u2022 <b>' + (t.skill || '') + '</b> ' + (t.change_pct || '') + '% — ' + (t.interpretation || '') + '\\n';\n  });\n  msg += '\\n';\n}\n\nmsg += '<b>🏆 ' + (lang === 'ru' ? 'Топ навыков:' : 'Top Skills:') + '</b>\\n';\n(r.top_skills_analysis || []).slice(0, 5).forEach((s, i) => {\n  msg += '  ' + (i+1) + '. <b>' + (s.skill || '') + '</b> (' + (s.importance_rating || '') + '/10)\\n';\n});\nmsg += '\\n';\n\nmsg += '<b>💡 ' + (lang === 'ru' ? 'Рекомендации:' : 'Recommendations:') + '</b>\\n';\n(r.recommendations || []).forEach((rec, i) => {\n  msg += '  ' + (i+1) + '. ' + rec + '\\n';\n});\n\nreturn [{ json: { telegram_html: msg, user_lang: lang, report_json: r, raw_data: $json.raw_data_summary, generated_at: $json.generated_at } }];"
      },
