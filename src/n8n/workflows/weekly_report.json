    {
      "parameters": {
        "jsCode": "const items = $input.all().map(i => i.json);\nconst lang = /[\\u0400-\\u04FF]/.test(JSON.stringify(items)) ? 'ru' : 'en';\n\n// Collect from all 5 sources by position\nconst pipelineStatus = items[0] || {};\nconst topSkills     = items[1] || {};\nconst trendsData    = items[2] || {};\nconst profilesData  = items[3] || {};\nconst vacancyStats  = items[4] || {};\n\nconst skillsList = (topSkills.skills || topSkills.data || topSkills).slice(0, 15);\nconst trends = trendsData.trends || trendsData.data || trendsData;\nconst profiles = profilesData.profiles || profilesData.data || profilesData;\n\nreturn [{\n  json: {\n    pipeline_status: pipelineStatus,\n    top_skills: skillsList,\n    trends: typeof trends === 'object' && !Array.isArray(trends) ? trends : { trends_list: trends },\n    profiles: typeof profiles === 'object' && !Array.isArray(profiles) ? profiles : { list: profiles },\n    vacancy_stats: vacancyStats,\n    generated_at: new Date().toISOString(),\n    user_lang: lang\n  }\n}];"
      },
